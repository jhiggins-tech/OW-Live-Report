# V2 runtime config — Vite reads VITE_* at build time.
# Non-secret values that should vary per-environment without a rebuild
# go into docs/v2/data/runtime-config.json (see V2.1 checklist).

VITE_INFLUX_QUERY_URL=https://owstats.jhiggins.tech/query
VITE_INFLUX_DATABASE=ow_stats_telegraf
VITE_INFLUX_GAMEMODE=competitive
VITE_TEAM_NAME=Weasels
VITE_TEAM_SUBTITLE=Live competitive reporting with team and player drill-downs.
VITE_TOP_HERO_COUNT=6
VITE_LINK_TO_V1_URL=../
