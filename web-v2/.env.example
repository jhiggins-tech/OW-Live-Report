# V2 runtime config contract.
#
# These values flow into docs/v2/data/runtime-config.json at build time via
# scripts/build-runtime-config.mjs. The app fetches that JSON on boot, so
# changing any of these values requires only a rebuild + redeploy of the
# config file — no Vite bundle rebuild is strictly necessary.
#
# Either the unprefixed or VITE_-prefixed name works. The build script reads
# either; the VITE_ prefix is here for parity with the Vite convention used
# by other projects, not because the bundle reads import.meta.env (it doesn't).
#
# All values are non-secret. Defaults live in src/lib/runtimeConfig.ts.

# --- Team identity ---
TEAM_NAME=Weasels
TEAM_SUBTITLE=Live competitive reporting with team and player drill-downs.

# --- UI ---
TOP_HERO_COUNT=6

# --- InfluxDB endpoint ---
# Must respond with Access-Control-Allow-Origin: *.
INFLUX_QUERY_URL=https://owstats.jhiggins.tech/query
INFLUX_DATABASE=ow_stats_telegraf
INFLUX_GAMEMODE=competitive
