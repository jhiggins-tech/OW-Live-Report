{
  "name": "ow-live-report-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:roster": "node scripts/build-roster.mjs",
    "build:config": "node scripts/build-runtime-config.mjs",
    "build:stubs": "node scripts/build-stubs.mjs",
    "prebuild": "pnpm run build:roster && pnpm run build:config",
    "dev": "pnpm run prebuild && vite",
    "build": "pnpm run prebuild && tsc --noEmit && vite build && pnpm run build:stubs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/query-sync-storage-persister": "^5.59.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-persist-client": "^5.59.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
